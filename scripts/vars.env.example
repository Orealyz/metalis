# vars.env.example — Variables de déploiement METALIS
# Copier ce fichier en vars.env et adapter les valeurs avant lancement

# Nœud Proxmox (nom affiché dans l'interface)
PROXMOX_NODE=pve

# Pool de stockage Proxmox (local-lvm, ceph-pool, etc.)
STORAGE_POOL=local-lvm

# Bridge réseau principal (VLAN-aware)
BRIDGE=vmbr0

# Stockage des ISOs
ISO_STORAGE=local

# Mot de passe root / cloud-init des VMs (à changer absolument)
VM_PASSWORD=ChangeMe123!

# Rétention des snapshots automatiques (jours)
SNAPSHOT_RETENTION_DAYS=7
